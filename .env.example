VITE_APP_URL=http://localhost:5173

# Azure Cosmos DB free tier account settings.
COSMOS_ENDPOINT=https://your-free-cosmos-account.documents.azure.com:443/
COSMOS_KEY=replace-with-primary-key
COSMOS_DATABASE=sentrasec

# Optional SMTP for welcome emails. If omitted, the API stores the event only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SentraSec <no-reply@sentrasec.io>

# OAuth secrets belong in Azure Static Web Apps application settings, not in frontend code.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://your-static-web-app.azurestaticapps.net
